<!DOCTYPE html>
<html>
<head>
<style>
.camera{
    width:180px;
    height:120px;
    background:black;
    border-radius:15px;
    position:relative;
}

.lens{
    width:60px;
    height:60px;
    background:white;
    border-radius:50%;
    position:absolute;
    top:30px;
    left:60px;
}
</style>
</head>
<body>

<div class="camera">
    <div class="lens"></div>
</div>

</body>
</html>